{
  "$schema": "https://schema.railway.app/railway-v2-schema.json",
  "build": {
    "buildCommand": "npm install -g pnpm && pnpm install && pnpm --filter @workspace/api-server build"
  },
  "deploy": {
    "startCommand": "node --enable-source-maps ./artifacts/api-server/dist/index.mjs",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
